# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── LLM ───────────────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | groq
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=duckdb:///./data/local.duckdb

# ─── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── GCS ───────────────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
